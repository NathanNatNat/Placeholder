{
    "window": {
        "width": 1920,
        "height": 1080,
        "title": "Placeholder Engine",
        "fullscreen": false
    },
    "rendering": {
        "vsync": true
    },
    "wow": {
        "dataPath": ""
    },
    "input": {
        "bindings": [
            { "action": "MoveForward",  "type": "hold", "key": "W" },
            { "action": "MoveBack",     "type": "hold", "key": "S" },
            { "action": "MoveLeft",     "type": "hold", "key": "A" },
            { "action": "MoveRight",    "type": "hold", "key": "D" },
            { "action": "MoveUp",       "type": "hold", "key": "Space" },
            { "action": "MoveDown",     "type": "hold", "key": "LeftShift" },
            { "action": "Look",         "type": "axis", "mouseButton": "Middle" },
            { "action": "Pan",          "type": "axis", "mouseButton": "Middle", "modifierKey": "LeftShift" },
            { "action": "ToggleWireframe", "type": "trigger", "key": "F1" },
            { "action": "ToggleCamera",    "type": "trigger", "key": "F2" }
        ]
    }
}
